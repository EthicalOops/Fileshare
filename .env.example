# ─────────────────────────────────────────────
# FileDropp — Email Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Gmail (most common) ──────────────────────
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Generate an "App Password" (you need 2FA enabled)
# 3. Use that 16-character password as SMTP_PASS (NOT your Gmail password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# ── Outlook / Hotmail ────────────────────────
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@outlook.com
# SMTP_PASS=your-password

# ── Yahoo Mail ───────────────────────────────
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@yahoo.com
# SMTP_PASS=your-app-password

# ── Resend (recommended for production) ──────
# Sign up free at https://resend.com
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here
